NODE_ENV=development
PORT=8000
API_VERSION=v1

# Database
DATABASE_URL=postgres://expenseflow:expenseflow@localhost:5432/expenseflow
DB_HOST=localhost
DB_PORT=5432
DB_NAME=expenseflow
DB_USER=expenseflow
DB_PASSWORD=expenseflow

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=ExpenseFlow <noreply@expenseflow.app>

# AWS S3
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=expenseflow-receipts

# OpenAI
OPENAI_API_KEY=

# RevenueCat
REVENUECAT_WEBHOOK_SECRET=

# OAuth (optional — validates social login tokens)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Monitoring & Analytics
SENTRY_DSN=
POSTHOG_API_KEY=

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=

# App
APP_URL=http://localhost:3000
CORS_ORIGIN=*
